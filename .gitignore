# =============================================================================
# Claude Code — contains API keys and local permissions, never commit
# =============================================================================
.claude/

# =============================================================================
# Quarto — build output (deployed to gh-pages branch by GitHub Actions)
# =============================================================================
/.quarto/
/docs/
*_files/
*_cache/
*.quarto_ipynb

# =============================================================================
# Python
# =============================================================================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.pyc

# Virtual environments
.venv/
venv/
env/
.env

# uv
.python-version

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Distribution / packaging
*.egg-info/
dist/
build/

# =============================================================================
# Instructor / restricted content — never commit
# =============================================================================
instructor/answer-keys/
instructor/planning/

# =============================================================================
# R leftovers
# =============================================================================
.Rhistory
.RData
.Ruserdata

# =============================================================================
# Rendered slide HTML — built by `make slides`, deployed via docs/
# =============================================================================
slides/*.html

# =============================================================================
# macOS
# =============================================================================
.DS_Store
.AppleDouble
.LSOverride

# =============================================================================
# Editors
# =============================================================================
.vscode/settings.json
*.swp
*.swo
